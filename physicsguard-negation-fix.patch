+# -- Negation handling tests ----------------------------------------------------
+
+@pytest.mark.parametrize("premise,expected", [
+    # Negated violations should be recognized as valid physics
+    ("We cannot create energy from nothing", "CLEAN"),
+    ("Energy is not created from nothing", "CLEAN"),
+    ("It is impossible to build a perpetual motion machine", "CLEAN"),
+    # Negated conservation should be recognized as violations
+    ("No energy is conserved", "CORRUPTED"),
+    ("Energy is not conserved in this process", "CORRUPTED"),
+    # Cost denial without action verb
+    ("no energy cost involved here", "CORRUPTED"),
+    ("there is no entropy cost", "CORRUPTED"),
+])
+def test_negation_handling(premise, expected):
+    result = check(premise)
+    assert result["verdict"] == expected, (
+        f"Expected {expected} for: {premise!r}, "
+        f"got {result['verdict']} (pattern={result['audit'].get('claim_pattern', '?')})"
+    )
+
+
 def test_empty_premise():
     result = check("")
     assert result["verdict"] in ("CLEAN", "SUSPECT", "CORRUPTED")
